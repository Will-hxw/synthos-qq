{
    "dataProviders": {
        "QQ": {
            "VFSExtPath": "./assets/sqlite_vfs_plugins/win_x86/sqlite_ext_ntqq_db.dll",
            "dbBasePath": "C:/Users/<用户名>/Documents/Tencent Files/<QQ号>/nt_qq/nt_db",
            "dbKey": "password",
            "dbPatch": {
                "enabled": false,
                "patchSQL": ""
            }
        }
    },
    "preprocessors": {
        "AccumulativeSplitter": {
            "mode": "charCount",
            "maxCharCount": 2000,
            "maxMessageCount": 50,
            "persistentKVStorePath": "./data/splitter-kv"
        },
        "TimeoutSplitter": {
            "timeoutInMinutes": 30
        }
    },
    "ai": {
        "models": {
            "example-model": {
                "apiKey": "replace-with-llm-api-key",
                "baseURL": "https://api.example.com/v1",
                "temperature": 0.7,
                "maxTokens": 100000
            }
        },
        "defaultModelConfig": {
            "apiKey": "replace-with-llm-api-key",
            "baseURL": "https://api.example.com/v1",
            "temperature": 0.7,
            "maxTokens": 100000
        },
        "defaultModelName": "example-model",
        "pinnedModels": ["example-model"],
        "maxConcurrentRequests": 10,
