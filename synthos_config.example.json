    "webUI_Backend": {
        "port": 3002,
        "kvStoreBasePath": "./data/kv-store",
        "dbBasePath": "./data"
    },
    "orchestrator": {
        "pipelineIntervalInMinutes": 60,
        "dataSeekTimeWindowInHours": 24
    },
    "webUI_Forwarder": {
        "enabled": false,
        "authTokenForFE": "",
        "authTokenForBE": ""
    },
    "commonDatabase": {
        "dbBasePath": "./data",
        "maxDBDuration": 90,
        "ftsDatabase": {
            "imMessageDBPath": "./data/fts_messages.db"
        }
    },
    "logger": {
        "logLevel": "info",
        "logDirectory": "./logs"
    },
    "groupConfigs": {
        "example-group": {
            "IM": "QQ",
            "groupName": "示例群",
            "splitStrategy": "accumulative",
            "groupIntroduction": "",
            "aiModels": ["example-model"]
        }
    },
    "email": {
        "enabled": false,
        "smtp": {
            "host": "smtp.qq.com",
            "port": 465,
            "secure": true,
            "user": "",
            "pass": ""
        },
        "from": "",
        "recipients": [],
        "retryCount": 3
    },
    "report": {
        "enabled": true,
        "sendEmail": false,
        "schedule": {
            "halfDailyTimes": [
                "12:00",
                "18:00"
            ],
            "weeklyTime": "20:00",
            "weeklyDayOfWeek": 1,
            "monthlyTime": "20:00",
            "monthlyDayOfMonth": 1
        },
        "generation": {
            "topNTopics": 20,
            "interestScoreThreshold": 0,
            "llmRetryCount": 3,
            "aiModels": ["example-model"]
        }
    },
    "preStartCommand": {
        "enabled": false,
        "command": "",
        "silent": false,
        "detached": false
    }
